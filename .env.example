# ─────────────────────────────────────────────────────────────────────────────
# Agent Saan — Environment Variables
# Copy this file to .env and fill in the values before running the application.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM / AI API Keys ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ELEVENLABS_API_KEY=...

# ── Database ─────────────────────────────────────────────────────────────────
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+asyncpg://agent_saan:changeme@localhost:5432/agent_saan

# ── Redis (Event Bus + Short-Term Memory) ────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Authentication ───────────────────────────────────────────────────────────
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=changeme-replace-with-a-strong-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Safety / Rate Limiting ───────────────────────────────────────────────────
ACTION_RATE_LIMIT_DEFAULT=100
ACTION_RATE_LIMIT_MAX=1000

# ── Short-Term Memory ────────────────────────────────────────────────────────
STM_MAX_TURNS=50
STM_TTL_MINUTES=30

# ── Plugin System ────────────────────────────────────────────────────────────
PLUGIN_DEFAULT_TIMEOUT_SECONDS=10

# ── Logging ──────────────────────────────────────────────────────────────────
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ── OpenTelemetry ────────────────────────────────────────────────────────────
# OTLP gRPC endpoint for traces (e.g. http://localhost:4317)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=agent-saan

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true
